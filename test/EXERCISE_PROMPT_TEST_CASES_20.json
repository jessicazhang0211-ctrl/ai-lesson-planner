{
  "suite": "exercise_prompt_generation",
  "api": "/api/exercise/generate",
  "method": "POST",
  "count": 20,
  "cases": [
    {
      "case_id": "E001",
      "name": "grade1_addition_single_choice",
      "payload": {
        "grade": "一年级",
        "subject": "数学",
        "topic": "20以内加法",
        "types": ["single"],
        "difficulty": "简单",
        "count": 10,
        "includeAnswer": true
      },
      "expected": {
        "http_status": 200,
        "output_should_be_json": true,
        "questions_min": 10
      }
    },
    {
      "case_id": "E002",
      "name": "grade2_mixed_objective_types",
      "payload": {
        "grade": "二年级",
        "subject": "数学",
        "topic": "表内乘法",
        "types": ["single", "true_false", "fill"],
        "difficulty": "中等",
        "count": 12,
        "includeAnswer": true
      },
      "expected": {"http_status": 200}
    },
    {
      "case_id": "E003",
      "name": "grade3_multi_choice",
      "payload": {
        "grade": "三年级",
        "subject": "数学",
