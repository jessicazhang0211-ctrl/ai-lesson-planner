        "note": "backend prompt currently does not branch by includeAnswer"
      }
    },
    {
      "case_id": "E019",
      "name": "types_as_string_invalid_shape",
      "payload": {
        "grade": "三年级",
        "subject": "数学",
        "topic": "分数初步",
        "types": "single,multi",
        "difficulty": "中等",
        "count": 10,
        "includeAnswer": true
      },
      "expected": {
        "http_status": 500,
        "note": "expected join error when types is not array"
      }
    },
    {
      "case_id": "E020",
      "name": "missing_types_field",
      "payload": {
        "grade": "三年级",
        "subject": "数学",
        "topic": "分数初步",
        "difficulty": "中等",
        "count": 10,
        "includeAnswer": true
      },
      "expected": {
        "http_status": 200,
        "note": "backend defaults types to empty list"
      }
